# ─────────────────────────────────────────────────────────────────────────────
# Firebase configuration — the ONLY place the backend is wired.
# Copy this file to `.env` and fill in the values from your Firebase project:
#   Firebase console → Project settings → General → "Your apps" → SDK setup.
#
# Handover: the client creates their own Firebase project, drops its config here,
# runs `npm run seed`, then `firebase deploy`. No code changes required.
#
# NOTE: local development does NOT need this file — a committed `.env.development`
# already points the app at the emulator. This template is for a REAL project.
# ─────────────────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Empty/false → talk to the real project above (the production default). Set to
# "true" only to point this file at the local Emulator Suite. Day-to-day local
# dev already uses the emulator via `.env.development`, so leave this empty.
VITE_USE_EMULATOR=
