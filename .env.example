# ─────────────────────────────────────────────────────────────────────────────
# Firebase configuration — the ONLY place the backend is wired.
# Copy this file to `.env` and fill in the values from your Firebase project:
#   Firebase console → Project settings → General → "Your apps" → SDK setup.
#
# Handover: the client creates their own Firebase project, drops its config here,
# runs `npm run seed`, then `firebase deploy`. No code changes required.
# ─────────────────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" for local development against the Firebase Emulator Suite
# (no real project / billing needed). Leave empty/false in production.
VITE_USE_EMULATOR=true
